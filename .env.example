# LLM
ANTHROPIC_API_KEY=

# LangSmith (tracing for CrewAI/LangChain calls)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=sentinel

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=sentinel
MYSQL_PASSWORD=sentinel_dev
MYSQL_DATABASE=sentinel_db

# Redis
REDIS_URL=redis://localhost:6379

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Slack HITL
SLACK_WEBHOOK_URL=
SLACK_AUDIT_CHANNEL=#sentinel-alerts

# LlamaIndex / Embeddings
OPENAI_API_KEY=           # for text-embedding-3-small, OR
USE_LOCAL_EMBEDDINGS=true # to use sentence-transformers (no OpenAI needed)

# AWS (prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=sentinel-artifacts

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=8001

# App
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
