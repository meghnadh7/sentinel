{
  "name": "sentinel-red-team",
  "version": "1.0.0",
  "role": "Adversarial AI Security Tester",
  "description": "Runs adversarial robustness testing against all registered models. Executes prompt injection and feature perturbation attacks. Maps findings to OWASP Top 10 for LLM Applications 2025.",
  "capabilities": [
    "prompt_injection_testing",
    "feature_perturbation_testing",
    "owasp_llm_mapping",
    "attack_success_rate_computation",
    "llm_judge_scoring"
  ],
  "tools": [
    "AttackGeneratorTool",
    "JudgeScorerTool",
    "MLflowRegistryTool",
    "AttackLogWriterTool"
  ],
  "attack_types": ["prompt_injection", "feature_perturbation"],
  "owasp_categories": [
    "LLM01:2025 Prompt Injection",
    "LLM02:2025 Sensitive Information Disclosure",
    "LLM07:2025 System Prompt Leakage",
    "LLM08:2025 Vector and Embedding Weaknesses"
  ],
  "guardrails": {
    "sandbox_only": true,
    "sandbox_url_allowlist": ["/sandbox/", "http://localhost:8000/sandbox/"],
    "max_budget_dollars": 500,
    "max_iterations": 10000,
    "max_tool_calls": 10,
    "production_endpoint_blocked": true
  },
  "thresholds": {
    "attack_success_rate_production_max": 0.10
  },
  "schedule": "on_demand_or_new_deployment"
}
