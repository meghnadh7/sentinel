{
  "title": "Sentinel — AI Compliance Dashboard",
  "uid": "sentinel-compliance",
  "version": 1,
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Fairness Alerts (Action Level)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(sentinel_fairness_alert_total{alert_level=\"action\"})",
          "legendFormat": "Action Alerts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Audit Log Chain Validity",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sentinel_audit_log_chain_valid",
          "legendFormat": "Chain Valid"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "COMPROMISED", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "INTACT", "color": "green"}}}
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Red Team Attack Success Rate",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sentinel_red_team_attack_success_rate",
          "legendFormat": "{{model_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.10}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "SHAP Stability Score",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sentinel_shap_stability_score",
          "legendFormat": "{{model_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.85},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Fairness Alerts by Protected Class",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "rate(sentinel_fairness_alert_total[5m])",
          "legendFormat": "{{protected_class}} ({{alert_level}})"
        }
      ]
    },
    {
      "id": 6,
      "title": "Audit Duration by Agent",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(sentinel_audit_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{agent}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Documentation Completeness Score",
      "type": "bargauge",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sentinel_doc_completeness_score",
          "legendFormat": "{{model_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.80},
              {"color": "green", "value": 0.90}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Governance Gate Status",
      "type": "table",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "sentinel_governance_gate_passed",
          "legendFormat": "{{model_id}} — {{gate_name}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "LLM Audit Cost (cumulative $)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(sentinel_audit_cost_dollars)",
          "legendFormat": "Total Cost ($)"
        }
      ]
    }
  ],
  "time": {"from": "now-24h", "to": "now"},
  "refresh": "30s"
}
